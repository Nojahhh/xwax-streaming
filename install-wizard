# install-wizard: interactive Linux install helper for xwax.
#
# Probes the host (distro, CPU, audio backends, libs, hardware), drives
# the existing configure/make/install pipeline with user confirmation,
# and optionally sets up the streaming integration (system tool
# detection, Python venv for scan-spotify, Spotify client id capture).
#
# This script is interactive. For non-interactive scripted setups, use
# ./configure directly.
#

set -u

# ---- Output helpers ---------------------------------------------------------

if [ -t 1 ] && [ "${TERM:-dumb}" != "dumb" ]; then
	C_BOLD=$(printf '\033[1m')
	C_DIM=$(printf '\033[2m')
	C_RED=$(printf '\033[31m')
	C_GREEN=$(printf '\033[32m')
	C_YELLOW=$(printf '\033[33m')
	C_BLUE=$(printf '\033[34m')
	C_RESET=$(printf '\033[0m')
else
	C_BOLD=''
	C_DIM=''
	C_RED=''
	C_GREEN=''
	C_YELLOW=''
	C_BLUE=''
	C_RESET=''
fi

heading() {
	printf '\n%s== %s ==%s\n' "$C_BOLD" "$1" "$C_RESET"
}

info() {
	printf '  %s\n' "$1"
}

ok() {
	printf '  %s[ ok ]%s %s\n' "$C_GREEN" "$C_RESET" "$1"
}

warn() {
	printf '  %s[warn]%s %s\n' "$C_YELLOW" "$C_RESET" "$1"
}

err() {
	printf '  %s[fail]%s %s\n' "$C_RED" "$C_RESET" "$1" >&2
}

die() {
	err "$1"
	exit 1
}

# ---- Prompts ----------------------------------------------------------------
# ask_yn QUESTION DEFAULT (Y or N) -> sets REPLY to y/n

ask_yn() {
	_q=$1
	_def=$2
	if [ "$_def" = "Y" ]; then
		_hint="[Y/n]"
	else
		_hint="[y/N]"
	fi
	while :; do
		printf '  %s %s ' "$_q" "$_hint"
		if ! IFS= read -r _ans; then
			REPLY=$(printf '%s' "$_def" | tr '[:upper:]' '[:lower:]')
			printf '\n'
			return 0
		fi
		if [ -z "$_ans" ]; then
			REPLY=$(printf '%s' "$_def" | tr '[:upper:]' '[:lower:]')
			return 0
		fi
		case $_ans in
			y|Y|yes|YES) REPLY=y ; return 0 ;;
			n|N|no|NO)   REPLY=n ; return 0 ;;
			*) printf '  Please answer y or n.\n' ;;
		esac
	done
}

# ask_str QUESTION DEFAULT -> sets REPLY to the entered string (or default)

ask_str() {
	_q=$1
	_def=$2
	if [ -n "$_def" ]; then
		printf '  %s [%s] ' "$_q" "$_def"
	else
		printf '  %s ' "$_q"
	fi
	if ! IFS= read -r _ans; then
		REPLY=$_def
		printf '\n'
		return 0
	fi
	if [ -z "$_ans" ]; then
		REPLY=$_def
	else
		REPLY=$_ans
	fi
}

# ask_choice QUESTION DEFAULT OPT1 OPT2 ... -> sets REPLY to chosen option

ask_choice() {
	_q=$1
	_def=$2
	shift 2
	_opts=$*
	while :; do
		printf '  %s (%s) [%s] ' "$_q" "$(echo "$_opts" | tr ' ' '/')" "$_def"
		if ! IFS= read -r _ans; then
			REPLY=$_def
			printf '\n'
			return 0
		fi
		if [ -z "$_ans" ]; then
			REPLY=$_def
			return 0
		fi
		for _o in $_opts; do
			if [ "$_ans" = "$_o" ]; then
				REPLY=$_ans
				return 0
			fi
		done
		printf '  Please answer one of: %s.\n' "$_opts"
	done
}

# ---- Argument parsing -------------------------------------------------------

usage() {
	cat <<EOF
Usage: install-wizard [--help]

Interactive installer for xwax. Probes audio backends, libraries, and
hardware on the local Linux host, then drives configure/make/install
with confirmation at each step. Also offers to set up the streaming
integration (ffmpeg/yt-dlp/jq detection, spotty fork of librespot for
Spotify --single-track support, Python venv for scan-spotify, Spotify
client id capture).

For non-interactive / scripted setups use ./configure directly.

Options:
  --help    Show this help and exit.
EOF
}

while [ $# -ge 1 ]; do
	case $1 in
		--help|-h) usage; exit 0 ;;
		*) err "unknown option: $1"; usage; exit 1 ;;
	esac
	shift
done

# ---- Section 1: Sanity checks -----------------------------------------------

heading "Sanity checks"

if [ "$(uname -s)" != "Linux" ]; then
	die "this wizard is for Linux only (detected $(uname -s)). Use ./configure manually on other systems."
fi
ok "Linux host"

WIZARD_DIR=$(cd "$(dirname "$0")" && pwd)
cd "$WIZARD_DIR" || die "cannot cd to script directory"

if [ ! -f Makefile ] || [ ! -f configure ]; then
	die "must be run from the xwax source tree (Makefile and configure not found here)"
fi
ok "running from xwax source tree at $WIZARD_DIR"

MISSING_TOOLS=
for _t in make pkg-config; do
	if ! command -v "$_t" >/dev/null 2>&1; then
		MISSING_TOOLS="$MISSING_TOOLS $_t"
	fi
done
if ! command -v cc >/dev/null 2>&1 && ! command -v gcc >/dev/null 2>&1; then
	MISSING_TOOLS="$MISSING_TOOLS cc/gcc"
fi
if [ -n "$MISSING_TOOLS" ]; then
	err "missing required build tools:$MISSING_TOOLS"
	info "Debian/Ubuntu : sudo apt install build-essential pkg-config"
	info "Fedora/RHEL   : sudo dnf install gcc make pkgconf-pkg-config"
	info "Arch          : sudo pacman -S base-devel pkgconf"
	exit 1
fi
ok "build tools present (make, cc/gcc, pkg-config)"

# Refuse to run the whole wizard under sudo. Building xwax does not need
# root, and doing so leaves root-owned .config / .version / *.o files in
# the source tree that block any future non-root run. The install step
# acquires sudo on its own when the prefix is outside $HOME.

if [ "$(id -u)" -eq 0 ]; then
	if [ -n "${SUDO_USER:-}" ] && [ "$SUDO_USER" != "root" ]; then
		err "this wizard is being run via sudo (SUDO_USER=$SUDO_USER)."
		info "Run it as your normal user instead:"
		info "    ./install-wizard"
		info "The wizard will call 'sudo make install' itself only when"
		info "the install prefix is outside your home directory."
		info ""
		info "If you have already run it under sudo and it left root-owned"
		info "files behind, clean them up first with:"
		info "    sudo rm -f .config .version *.o tests/*.o xwax mktimecode"
		exit 1
	fi
	warn "running as the real root user (no SUDO_USER set)."
	warn "If this is intentional, continuing; otherwise hit Ctrl-C now."
fi

# Ensure the build helper scripts in the source tree are executable.
# Some clone paths (zip downloads, copying through Windows / non-POSIX
# filesystems) drop the execute bit, which then breaks './mkversion'
# from inside the Makefile and './configure' from this wizard.

_build_helpers="configure mkversion mkdist scan import"
_chmod_done=
for _h in $_build_helpers; do
	if [ -f "$_h" ] && [ ! -x "$_h" ]; then
		if chmod +x "$_h" 2>/dev/null; then
			_chmod_done="$_chmod_done $_h"
		else
			err "$_h is not executable and chmod +x failed (insufficient permission)."
			info "It may be owned by root from a previous sudo run. Try:"
			info "    sudo chown -R \"\$USER\":\"\$USER\" ."
			info "    chmod +x$_build_helpers"
			exit 1
		fi
	fi
done
if [ -n "$_chmod_done" ]; then
	ok "made build helpers executable:$_chmod_done"
else
	ok "build helpers already executable"
fi

# Detect stale root-owned source-tree artefacts left over from a previous
# 'sudo' run. These prevent ./configure from rewriting .config and break
# 'make' / 'make clean' for the current user.

_stale_root=
if [ "$(id -u)" -ne 0 ]; then
	for _f in .config .version; do
		if [ -e "$_f" ] && [ ! -w "$_f" ]; then
			_stale_root="$_stale_root $_f"
		fi
	done
fi
if [ -n "$_stale_root" ]; then
	warn "found files in the source tree you cannot write to (likely from a previous sudo run):$_stale_root"
	if command -v sudo >/dev/null 2>&1; then
		ask_yn "Remove them with sudo so this wizard can proceed?" "Y"
		if [ "$REPLY" = y ]; then
			# shellcheck disable=SC2086
			sudo rm -f $_stale_root || die "could not remove stale files; aborting."
			# Also clear any root-owned object files lurking in the tree.
			# 'make clean' would re-create them, but we want the build to
			# run under the current user, not error out on writes.
			sudo find . -maxdepth 2 -name '*.o' -user 0 -exec rm -f {} + 2>/dev/null || true
			sudo find . -maxdepth 2 -name '*.d' -user 0 -exec rm -f {} + 2>/dev/null || true
			ok "removed stale root-owned files"
		else
			die "aborting; please run 'sudo rm -f$_stale_root' manually and rerun."
		fi
	else
		die "sudo not available; remove these files manually as root and rerun: $_stale_root"
	fi
fi

# ---- Section 2: System probe ------------------------------------------------

heading "System probe"

DISTRO_ID=unknown
DISTRO_NAME="unknown Linux"
if [ -r /etc/os-release ]; then
	# shellcheck disable=SC1091
	. /etc/os-release
	DISTRO_ID=${ID:-unknown}
	DISTRO_NAME=${PRETTY_NAME:-$DISTRO_ID}
fi
info "distro:        $DISTRO_NAME"

ARCH=$(uname -m)
info "architecture:  $ARCH"

PI4_DETECTED=false
if [ -r /proc/cpuinfo ]; then
	if grep -q "Raspberry Pi 4" /proc/cpuinfo 2>/dev/null \
		|| grep -q "BCM2711" /proc/cpuinfo 2>/dev/null; then
		PI4_DETECTED=true
	fi
fi
if $PI4_DETECTED; then
	info "platform:      Raspberry Pi 4 (BCM2711) detected"
fi

# pkg_install_hint TOKEN: print distro-appropriate install line for TOKEN.
# TOKEN is one of: sdl2 sdl2_ttf alsa jack oss ffmpeg yt-dlp jq librespot venv

pkg_install_hint() {
	case $1 in
		sdl2)
			case $DISTRO_ID in
				debian|ubuntu|raspbian|linuxmint|pop) printf 'sudo apt install libsdl2-dev' ;;
				fedora|rhel|centos|rocky|almalinux)   printf 'sudo dnf install SDL2-devel' ;;
				arch|manjaro|endeavouros)             printf 'sudo pacman -S sdl2' ;;
				opensuse*|sles)                       printf 'sudo zypper install libSDL2-devel' ;;
				*)                                    printf 'install SDL2 development headers' ;;
			esac ;;
		sdl2_ttf)
			case $DISTRO_ID in
				debian|ubuntu|raspbian|linuxmint|pop) printf 'sudo apt install libsdl2-ttf-dev' ;;
				fedora|rhel|centos|rocky|almalinux)   printf 'sudo dnf install SDL2_ttf-devel' ;;
				arch|manjaro|endeavouros)             printf 'sudo pacman -S sdl2_ttf' ;;
				opensuse*|sles)                       printf 'sudo zypper install libSDL2_ttf-devel' ;;
				*)                                    printf 'install SDL2_ttf development headers' ;;
			esac ;;
		alsa)
			case $DISTRO_ID in
				debian|ubuntu|raspbian|linuxmint|pop) printf 'sudo apt install libasound2-dev alsa-utils' ;;
				fedora|rhel|centos|rocky|almalinux)   printf 'sudo dnf install alsa-lib-devel alsa-utils' ;;
				arch|manjaro|endeavouros)             printf 'sudo pacman -S alsa-lib alsa-utils' ;;
				opensuse*|sles)                       printf 'sudo zypper install alsa-devel alsa-utils' ;;
				*)                                    printf 'install ALSA development headers' ;;
			esac ;;
		jack)
			case $DISTRO_ID in
				debian|ubuntu|raspbian|linuxmint|pop) printf 'sudo apt install libjack-jackd2-dev (or libjack-dev)' ;;
				fedora|rhel|centos|rocky|almalinux)   printf 'sudo dnf install jack-audio-connection-kit-devel' ;;
				arch|manjaro|endeavouros)             printf 'sudo pacman -S jack2' ;;
				opensuse*|sles)                       printf 'sudo zypper install libjack-devel' ;;
				*)                                    printf 'install JACK development headers' ;;
			esac ;;
		oss)
			printf 'install OSS soundcard.h headers (rare on modern Linux)' ;;
		ffmpeg)
			case $DISTRO_ID in
				debian|ubuntu|raspbian|linuxmint|pop) printf 'sudo apt install ffmpeg' ;;
				fedora|rhel|centos|rocky|almalinux)   printf 'sudo dnf install ffmpeg' ;;
				arch|manjaro|endeavouros)             printf 'sudo pacman -S ffmpeg' ;;
				opensuse*|sles)                       printf 'sudo zypper install ffmpeg' ;;
				*)                                    printf 'install ffmpeg' ;;
			esac ;;
		mpg123)
			case $DISTRO_ID in
				debian|ubuntu|raspbian|linuxmint|pop) printf 'sudo apt install mpg123' ;;
				fedora|rhel|centos|rocky|almalinux)   printf 'sudo dnf install mpg123' ;;
				arch|manjaro|endeavouros)             printf 'sudo pacman -S mpg123' ;;
				opensuse*|sles)                       printf 'sudo zypper install mpg123' ;;
				*)                                    printf 'install mpg123' ;;
			esac ;;
		yt-dlp)
			case $DISTRO_ID in
				debian|ubuntu|raspbian|linuxmint|pop) printf 'sudo apt install yt-dlp  (or: pipx install yt-dlp)' ;;
				fedora|rhel|centos|rocky|almalinux)   printf 'sudo dnf install yt-dlp' ;;
				arch|manjaro|endeavouros)             printf 'sudo pacman -S yt-dlp' ;;
				opensuse*|sles)                       printf 'sudo zypper install yt-dlp' ;;
				*)                                    printf 'install yt-dlp (https://github.com/yt-dlp/yt-dlp)' ;;
			esac ;;
		jq)
			case $DISTRO_ID in
				debian|ubuntu|raspbian|linuxmint|pop) printf 'sudo apt install jq' ;;
				fedora|rhel|centos|rocky|almalinux)   printf 'sudo dnf install jq' ;;
				arch|manjaro|endeavouros)             printf 'sudo pacman -S jq' ;;
				opensuse*|sles)                       printf 'sudo zypper install jq' ;;
				*)                                    printf 'install jq' ;;
			esac ;;
		librespot)
			printf 'cargo install --git https://github.com/michaelherger/librespot --branch spotty spotty   (the "spotty" librespot fork; mainline lacks --single-track)' ;;
		venv)
			case $DISTRO_ID in
				debian|ubuntu|raspbian|linuxmint|pop) printf 'sudo apt install python3-venv python3-pip' ;;
				fedora|rhel|centos|rocky|almalinux)   printf 'sudo dnf install python3 python3-pip' ;;
				arch|manjaro|endeavouros)             printf 'sudo pacman -S python python-pip' ;;
				opensuse*|sles)                       printf 'sudo zypper install python3 python3-pip' ;;
				*)                                    printf 'install python3 + venv + pip' ;;
			esac ;;
	esac
}

# Required: SDL2 + SDL2_ttf

REQ_MISSING=
if pkg-config --exists sdl2 2>/dev/null; then
	SDL2_VER=$(pkg-config --modversion sdl2 2>/dev/null)
	ok "SDL2 ${SDL2_VER:-found}"
else
	err "SDL2 development files not found"
	REQ_MISSING="$REQ_MISSING sdl2"
fi

SDL2_TTF_OK=false
if pkg-config --exists SDL2_ttf 2>/dev/null; then
	SDL2_TTF_VER=$(pkg-config --modversion SDL2_ttf 2>/dev/null)
	ok "SDL2_ttf ${SDL2_TTF_VER:-found}"
	SDL2_TTF_OK=true
else
	# Some distros (older Debian) don't ship a .pc file for SDL2_ttf;
	# fall back to scanning the SDL2 include path for SDL_ttf.h.
	if pkg-config --exists sdl2 2>/dev/null; then
		SDL2_INCDIRS=$(pkg-config --cflags-only-I sdl2 2>/dev/null \
			| sed 's/-I//g')
		for _d in $SDL2_INCDIRS /usr/include /usr/include/SDL2 \
			/usr/local/include /usr/local/include/SDL2; do
			if [ -f "$_d/SDL_ttf.h" ]; then
				ok "SDL2_ttf found via header at $_d/SDL_ttf.h"
				SDL2_TTF_OK=true
				break
			fi
		done
	fi
	if ! $SDL2_TTF_OK; then
		err "SDL2_ttf development files not found"
		REQ_MISSING="$REQ_MISSING sdl2_ttf"
	fi
fi

# Optional: ALSA / JACK / OSS

ALSA_LIB_OK=false
if pkg-config --exists alsa 2>/dev/null; then
	ALSA_LIB_OK=true
	ok "ALSA library ($(pkg-config --modversion alsa 2>/dev/null))"
else
	info "ALSA library : not found"
fi

JACK_LIB_OK=false
if pkg-config --exists jack 2>/dev/null; then
	JACK_LIB_OK=true
	ok "JACK library ($(pkg-config --modversion jack 2>/dev/null))"
else
	info "JACK library : not found"
fi

OSS_LIB_OK=false
for _h in /usr/include/sys/soundcard.h /usr/local/include/sys/soundcard.h; do
	if [ -f "$_h" ]; then
		OSS_LIB_OK=true
		break
	fi
done
if $OSS_LIB_OK; then
	ok "OSS soundcard.h header"
else
	info "OSS headers  : not found"
fi

if [ -n "$REQ_MISSING" ]; then
	echo
	err "missing required dependencies; cannot continue."
	echo
	for _m in $REQ_MISSING; do
		printf '  %s : %s\n' "$_m" "$(pkg_install_hint "$_m")"
	done
	exit 1
fi

# ---- Section 3: Hardware enumeration ---------------------------------------

heading "Audio hardware"

ALSA_HAS_HW=false
ALSA_DEVICE_LINES=
if command -v aplay >/dev/null 2>&1; then
	ALSA_LIST=$(aplay -l 2>/dev/null | grep -E '^card [0-9]+' || true)
	if [ -n "$ALSA_LIST" ]; then
		ALSA_HAS_HW=true
		info "ALSA playback devices:"
		printf '%s\n' "$ALSA_LIST" | while IFS= read -r _line; do
			printf '    %s\n' "$_line"
		done
		ALSA_DEVICE_LINES=$ALSA_LIST
	else
		info "ALSA: no playback cards reported by aplay -l"
	fi
	if command -v arecord >/dev/null 2>&1; then
		ALSA_REC=$(arecord -l 2>/dev/null | grep -E '^card [0-9]+' || true)
		if [ -n "$ALSA_REC" ]; then
			info "ALSA capture devices:"
			printf '%s\n' "$ALSA_REC" | while IFS= read -r _line; do
				printf '    %s\n' "$_line"
			done
		fi
	fi
else
	info "ALSA: aplay not installed; skipping hardware enumeration"
fi

JACK_RUNNING=false
if command -v jack_control >/dev/null 2>&1; then
	if jack_control status 2>/dev/null | grep -qi started; then
		JACK_RUNNING=true
	fi
fi
if ! $JACK_RUNNING && command -v pgrep >/dev/null 2>&1; then
	if pgrep -x jackd >/dev/null 2>&1 \
		|| pgrep -f pipewire-jack >/dev/null 2>&1 \
		|| pgrep -x pipewire >/dev/null 2>&1; then
		JACK_RUNNING=true
	fi
fi
if $JACK_RUNNING; then
	info "JACK: server is running (or PipeWire JACK shim active)"
else
	info "JACK: no server running"
fi

OSS_HAS_HW=false
OSS_DEVICES=
for _d in /dev/dsp /dev/dsp0 /dev/dsp1 /dev/dsp2 /dev/sound/dsp \
	/dev/sound/dsp0 /dev/sound/dsp1; do
	if [ -e "$_d" ]; then
		OSS_HAS_HW=true
		OSS_DEVICES="$OSS_DEVICES $_d"
	fi
done
if $OSS_HAS_HW; then
	info "OSS device nodes:$OSS_DEVICES"
else
	info "OSS: no /dev/dsp* nodes present"
fi

# ---- Section 3b: Runtime media decoders ------------------------------------
#
# These are runtime helpers shelled out to by the stock 'import' script
# that ships with xwax (xwax/import in the source tree). They are
# independent of the streaming integration:
#
#   mpg123  - decodes local .mp3 files
#   ffmpeg  - fallback decoder for everything else (FLAC, WAV, AAC, ...)
#             and also used by import-streaming for resampling and the
#             yt-dlp pipe.
#
# We probe and warn unconditionally because xwax cannot play any local
# library track without at least one of these. Streaming-specific tools
# (yt-dlp, jq, spotty/librespot) are still handled later, only when the
# user opts into the streaming setup.

heading "Runtime media decoders"

info "checking decoders used by the stock import script..."
for _tool in mpg123 ffmpeg; do
	if command -v "$_tool" >/dev/null 2>&1; then
		ok "$_tool: $(command -v "$_tool")"
	else
		case $_tool in
			mpg123) _why="needed to decode local .mp3 files" ;;
			ffmpeg) _why="needed to decode non-mp3 local files (and used by import-streaming)" ;;
		esac
		warn "$_tool not found ($_why)"
		info "    install: $(pkg_install_hint "$_tool")"
	fi
done

# ---- Section 4: Interactive confirmation -----------------------------------

heading "Choose configuration"

# Smart defaults: Y if both library AND any matching hardware are present.

# ask_backend BACKEND_NAME LIB_OK HW_HINT INSTALL_HINT_TOKEN -> sets REPLY=y/n
# Loops until the user either says n, or says y AND the dev library is
# present. Prevents the build from compiling, say, jack.c without
# jack/jack.h.

ask_backend() {
	_name=$1
	_lib_ok=$2
	_hw_hint=$3
	_hint_token=$4
	if $_lib_ok && [ "$_hw_hint" = hw ]; then
		_def=Y
	elif $_lib_ok; then
		_def=Y
	else
		_def=N
	fi
	while :; do
		ask_yn "Enable $_name backend?" "$_def"
		if [ "$REPLY" = n ]; then
			return 0
		fi
		if $_lib_ok; then
			return 0
		fi
		err "$_name dev library not found; cannot enable this backend."
		info "    install : $(pkg_install_hint "$_hint_token")"
		info "    then re-run ./install-wizard"
		ask_yn "Re-prompt for $_name (after you install the headers in another terminal)?" "N"
		if [ "$REPLY" != y ]; then
			REPLY=n
			return 0
		fi
		# Re-probe so the next pass reflects what the user just installed.
		case $_hint_token in
			alsa) pkg-config --exists alsa 2>/dev/null && _lib_ok=true ;;
			jack) pkg-config --exists jack 2>/dev/null && _lib_ok=true ;;
			oss)
				for _h in /usr/include/sys/soundcard.h \
					/usr/local/include/sys/soundcard.h; do
					[ -f "$_h" ] && _lib_ok=true && break
				done
				;;
		esac
	done
}

_alsa_hw_hint=no
$ALSA_HAS_HW && _alsa_hw_hint=hw
ask_backend ALSA "$ALSA_LIB_OK" "$_alsa_hw_hint" alsa
ENABLE_ALSA=$REPLY

_jack_hw_hint=no
$JACK_RUNNING && _jack_hw_hint=hw
ask_backend JACK "$JACK_LIB_OK" "$_jack_hw_hint" jack
ENABLE_JACK=$REPLY

_oss_hw_hint=no
$OSS_HAS_HW && _oss_hw_hint=hw
ask_backend OSS "$OSS_LIB_OK" "$_oss_hw_hint" oss
ENABLE_OSS=$REPLY

if [ "$ENABLE_ALSA" = n ] && [ "$ENABLE_JACK" = n ] && [ "$ENABLE_OSS" = n ]; then
	warn "no audio backend selected; xwax will build but won't be able to open any audio device."
	ask_yn "Continue anyway?" "N"
	if [ "$REPLY" != y ]; then
		exit 1
	fi
fi

ENABLE_PI4=n
if $PI4_DETECTED; then
	ask_yn "Enable Raspberry Pi 4 CPU optimizations?" "Y"
	ENABLE_PI4=$REPLY
fi

