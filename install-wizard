# ---- Section 7: Streaming integration --------------------------------------

heading "Streaming sources (SoundCloud / Spotify)"

ask_yn "Set up streaming source helpers (scan-soundcloud, scan-spotify, import-streaming)?" "Y"
DO_STREAMING=$REPLY

STREAMING_VENV=""
STREAMING_VENV_BUILT=false
STREAMING_ENV_FILE=""
SPOTIFY_CONFIGURED=false
LIBRESPOT_OK=false
LIBRESPOT_HAS_SINGLE_TRACK=false
LIBRESPOT_BIN=""
LIBRESPOT_BIN_NAME=""
LIBRESPOT_CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/xwax/librespot"
LIBRESPOT_PAIRED=false

# Probe for a librespot-family binary in PATH and confirm it supports
# --single-track. We prefer 'spotty' (the michaelherger/librespot fork)
# because mainline librespot does NOT ship --single-track; only the
# spotty fork does. If only mainline 'librespot' is on PATH it will be
# detected but flagged as unable to drive import-streaming.
#
# Sets:
#   LIBRESPOT_OK              true if any binary was found
#   LIBRESPOT_HAS_SINGLE_TRACK true if that binary supports --single-track
#   LIBRESPOT_BIN             absolute path to the chosen binary
#   LIBRESPOT_BIN_NAME        'spotty' or 'librespot'
probe_librespot() {
	LIBRESPOT_OK=false
	LIBRESPOT_HAS_SINGLE_TRACK=false
	LIBRESPOT_BIN=""
	LIBRESPOT_BIN_NAME=""

	# Try spotty first; fall back to mainline librespot. Whichever has
	# --single-track wins; if neither does, we still record the binary
	# we found so the summary can be honest about it.
	for _cand in spotty librespot; do
		if command -v "$_cand" >/dev/null 2>&1; then
			_path=$(command -v "$_cand")
			if "$_cand" --help 2>&1 | grep -q -- '--single-track'; then
				LIBRESPOT_OK=true
				LIBRESPOT_HAS_SINGLE_TRACK=true
				LIBRESPOT_BIN=$_path
				LIBRESPOT_BIN_NAME=$_cand
				return 0
			fi
			# Remember the first found binary even if it lacks
			# --single-track, so the user gets a meaningful message
			# rather than "not installed".
			if [ -z "$LIBRESPOT_BIN" ]; then
				LIBRESPOT_OK=true
				LIBRESPOT_BIN=$_path
				LIBRESPOT_BIN_NAME=$_cand
			fi
		fi
	done
}

if [ "$DO_STREAMING" = y ]; then

	# 7a. System tool detection (detect-only for yt-dlp/jq).
	#
	# ffmpeg is intentionally NOT re-checked here: it's already probed
	# in Section 3b ("Runtime media decoders") because the stock import
	# script needs it for non-mp3 files even when streaming is disabled.
	# We only check the streaming-specific extras here.

	info "checking streaming-only system tools..."
	for _tool in yt-dlp jq; do
		if command -v "$_tool" >/dev/null 2>&1; then
			ok "$_tool: $(command -v "$_tool")"
		else
			warn "$_tool not found  ->  $(pkg_install_hint "$_tool")"
		fi
	done

	# librespot: detect, and offer to cargo-install if missing or too old.
	# We prefer the 'spotty' fork (michaelherger/librespot) because
	# import-streaming relies on --single-track, which mainline librespot
	# does not have. Spotty is librespot 0.8.0 + the helper feature flags
	# from the LMS Spotty plugin (single-track, get-token, etc).
	probe_librespot
	if $LIBRESPOT_OK; then
		ok "$LIBRESPOT_BIN_NAME: $LIBRESPOT_BIN"
		if $LIBRESPOT_HAS_SINGLE_TRACK; then
			ok "$LIBRESPOT_BIN_NAME supports --single-track"
		else
			warn "$LIBRESPOT_BIN_NAME does not support --single-track."
			info "Mainline librespot has never shipped this flag; only the"
			info "'spotty' fork does. import-streaming can't fetch Spotify"
			info "tracks without it, so the wizard will offer to install spotty."
		fi
	else
		warn "no librespot-family binary found (looked for: spotty, librespot)"
	fi

	if ! $LIBRESPOT_OK || ! $LIBRESPOT_HAS_SINGLE_TRACK; then
		echo
		info "We install the 'spotty' fork of librespot, which adds the"
		info "--single-track flag that import-streaming needs to fetch one"
		info "Spotify URI and exit. Source: https://github.com/michaelherger/librespot"
		info "(branch 'spotty'). Build dependencies needed: git, pkg-config,"
		info "libasound2-dev, libssl-dev (Debian/Ubuntu names)."
		info "On a Raspberry Pi 4 the compile typically takes 20-40 minutes."
		ask_yn "Install spotty now (clone + cargo install --path)?" "Y"
		if [ "$REPLY" = y ]; then
			# If cargo is missing, offer to install rustup first. This
			# is a recognised third-party install (sh.rustup.rs); we
			# show the URL up-front so the user is consenting to it.
			if ! command -v cargo >/dev/null 2>&1; then
				warn "cargo (the Rust toolchain) is not in PATH."
				info "Rustup installs the toolchain into ~/.rustup and ~/.cargo"
				info "(per-user, no sudo needed). The minimal profile is ~250 MB."
				info "Source: https://sh.rustup.rs (the official rustup installer)."
				ask_yn "Install Rust via rustup now?" "Y"
				if [ "$REPLY" = y ]; then
					if ! command -v curl >/dev/null 2>&1; then
						err "curl not found; cannot fetch the rustup installer."
						case $DISTRO_ID in
							debian|ubuntu|raspbian|linuxmint|pop)
								info "    sudo apt install curl" ;;
							fedora|rhel|centos|rocky|almalinux)
								info "    sudo dnf install curl" ;;
							arch|manjaro|endeavouros)
								info "    sudo pacman -S curl" ;;
							opensuse*|sles)
								info "    sudo zypper install curl" ;;
							*)
								info "    install curl" ;;
						esac
					else
						info "fetching rustup-init from https://sh.rustup.rs ..."
						if curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
							| sh -s -- -y --default-toolchain stable --profile minimal; then
							ok "rustup installed."
							# Source rustup's env file so cargo is on PATH for
							# the rest of this wizard run. Rustup's installer
							# also appends the source line to ~/.bashrc /
							# ~/.profile for future shells.
							if [ -f "$HOME/.cargo/env" ]; then
								# shellcheck disable=SC1091
								. "$HOME/.cargo/env"
							fi
							if [ -d "$HOME/.cargo/bin" ]; then
								case ":$PATH:" in
									*":$HOME/.cargo/bin:"*) ;;
									*) PATH="$HOME/.cargo/bin:$PATH" ; export PATH ;;
								esac
							fi
						else
							err "rustup install failed; see output above."
						fi
					fi
				fi
			fi
			if ! command -v cargo >/dev/null 2>&1; then
				err "cargo still not available; skipping librespot install."
				info "Re-run ./install-wizard once Rust is installed."
			else
				# Pre-flight spotty's native build deps (and git, which
				# we now use directly to clone the fork). Without this
				# we'd wait 30+ minutes for cargo to discover via the
				# openssl-sys crate that libssl-dev isn't installed,
				# or fail at clone-time without git installed.
				_librespot_missing=
				for _pc in openssl alsa; do
					if ! pkg-config --exists "$_pc" 2>/dev/null; then
						_librespot_missing="$_librespot_missing $_pc"
					fi
				done
				if ! command -v git >/dev/null 2>&1; then
					_librespot_missing="$_librespot_missing git"
				fi
				if [ -n "$_librespot_missing" ]; then
					err "spotty build deps missing:$_librespot_missing"
					case $DISTRO_ID in
						debian|ubuntu|raspbian|linuxmint|pop)
							info "    sudo apt install libssl-dev libasound2-dev pkg-config git"
							;;
						fedora|rhel|centos|rocky|almalinux)
							info "    sudo dnf install openssl-devel alsa-lib-devel pkgconf-pkg-config git"
							;;
						arch|manjaro|endeavouros)
							info "    sudo pacman -S openssl alsa-lib pkgconf git"
							;;
						opensuse*|sles)
							info "    sudo zypper install libopenssl-devel alsa-devel pkg-config git"
							;;
						*)
							info "    install openssl + alsa development headers, pkg-config and git"
							;;
					esac
					info "Install those, then re-run ./install-wizard."
					info "(skipping cargo invocation to avoid a 30+ min wasted compile)"
				else
					ok "spotty build deps present (openssl, alsa, git)"

					# spotty's build tree under TMPDIR runs to 2-3 GB.
					# On Raspberry Pi OS / many systemd defaults, /tmp is a
					# tmpfs sized around RAM/2 (often <1 GB), and cargo
					# install dies with ENOSPC. If TMPDIR has <4 GB free,
					# redirect to a disk-backed scratch dir under XDG_CACHE.
					_cargo_tmp_override=
					_tmp_target=${TMPDIR:-/tmp}
					_tmp_avail_kb=$(df -P "$_tmp_target" 2>/dev/null \
						| awk 'NR==2 {print $4 + 0}')
					if [ "${_tmp_avail_kb:-0}" -lt 4194304 ]; then
						_cargo_tmp_override="${XDG_CACHE_HOME:-$HOME/.cache}/xwax/cargo-tmp"
						mkdir -p "$_cargo_tmp_override" \
							|| die "could not create $_cargo_tmp_override"
						warn "$_tmp_target has only ~$((${_tmp_avail_kb:-0} / 1024)) MB free; cargo would run out of space."
						info "redirecting TMPDIR to $_cargo_tmp_override (disk-backed)"
					fi

					# Wrap the cargo invocation in a function so we can run
					# the same command both with and without the TMPDIR
					# override without duplicating arg lists.
					_run_cargo_install() {
						if [ -n "$_cargo_tmp_override" ]; then
							TMPDIR="$_cargo_tmp_override" cargo install "$@"
						else
							cargo install "$@"
						fi
					}

					# Build spotty from a manual git clone instead of
					# 'cargo install --git'. Reason: the spotty branch
					# does an unconditional include_str!("client_id.txt")
					# at compile time, but the file is .gitignore'd
					# upstream — the maintainer drops in their LMS
					# plugin's client id during their own builds. Plain
					# 'cargo install --git' therefore fails with
					#   error: couldn't read `src/client_id.txt`
					# We work around it by cloning to a known path,
					# writing an empty placeholder (spotty falls back
					# to the runtime --client-id flag if anything actually
					# needs the value, and our --single-track audio
					# fetch path doesn't), then using --path so the
					# patched checkout is what cargo compiles.
					#
					# --locked uses the fork's published Cargo.lock so we
					# get the exact dependency versions the upstream
					# maintainers tested. Without --locked, librespot
					# 0.8.0 hits a vergen-lib v0.1 vs v9.x trait clash
					# that fails the librespot-core build.rs.
					_spotty_repo='https://github.com/michaelherger/librespot'
					_spotty_branch='spotty'
					_spotty_src="${XDG_CACHE_HOME:-$HOME/.cache}/xwax/spotty-src"

					mkdir -p "$(dirname "$_spotty_src")" \
						|| die "could not create $(dirname "$_spotty_src")"

					if [ -d "$_spotty_src/.git" ]; then
						info "refreshing existing spotty checkout at $_spotty_src"
						(
							cd "$_spotty_src" || exit 1
							git fetch --depth 1 origin "$_spotty_branch" \
								&& git checkout -B "$_spotty_branch" \
									"origin/$_spotty_branch"
						) || warn "git fetch/checkout in $_spotty_src failed; continuing with the existing checkout"
					else
						info "cloning $_spotty_repo (branch $_spotty_branch) -> $_spotty_src"
						# rm any partial clone so 'git clone' doesn't refuse.
						rm -rf "$_spotty_src" 2>/dev/null || true
						if ! git clone --depth 1 \
								--branch "$_spotty_branch" \
								"$_spotty_repo" "$_spotty_src"; then
							err "git clone of spotty failed."
							info "Check your network and that $_spotty_repo exists."
							_spotty_src=
						fi
					fi

					if [ -n "$_spotty_src" ] && [ -d "$_spotty_src/src" ]; then
						# The placeholder. Empty content is fine: the
						# value is consumed only by code paths that
						# need a Spotify Web API client id (e.g.
						# --get-token), which import-streaming does
						# not exercise. Any feature that does need a
						# real id can be passed via --client-id.
						if [ ! -f "$_spotty_src/src/client_id.txt" ]; then
							: > "$_spotty_src/src/client_id.txt" \
								|| die "could not create $_spotty_src/src/client_id.txt"
							ok "wrote empty placeholder $_spotty_src/src/client_id.txt"
						fi

						info "running: cargo install --path $_spotty_src --locked"
						info "(long; output streams below)"
						if _run_cargo_install --path "$_spotty_src" --locked; then
							ok "cargo install spotty completed"
						else
							warn "locked install failed; retrying without --locked (slower, may hit version conflicts)"
							if _run_cargo_install --path "$_spotty_src"; then
								ok "cargo install spotty completed (unlocked)"
							else
								err "cargo install spotty failed."
								info "Check the cargo output above. Common causes:"
								info "  - outdated rustc (run: rustup update)"
								info "  - insufficient disk space (cargo writes to TMPDIR=${_cargo_tmp_override:-$_tmp_target})"
								info "  - upstream branch moved (the fork lives at"
								info "    $_spotty_repo branch '$_spotty_branch')"
							fi
						fi
					fi

					# Clean up the redirected tmpdir; ~3 GB of intermediate
					# rust artifacts aren't worth keeping after a successful
					# install (cargo's own ~/.cargo cache is separate).
					# We KEEP the spotty source checkout so a future
					# wizard run can do an incremental rebuild.
					if [ -n "$_cargo_tmp_override" ] && [ -d "$_cargo_tmp_override" ]; then
						rm -rf "$_cargo_tmp_override" 2>/dev/null || true
					fi
					# Make ~/.cargo/bin available for the rest of this wizard run.
					if [ -d "$HOME/.cargo/bin" ]; then
						case ":$PATH:" in
							*":$HOME/.cargo/bin:"*) ;;
							*) PATH="$HOME/.cargo/bin:$PATH" ; export PATH ;;
						esac
					fi
					probe_librespot
					if $LIBRESPOT_OK; then
						ok "$LIBRESPOT_BIN_NAME now in PATH: $LIBRESPOT_BIN"
						if ! $LIBRESPOT_HAS_SINGLE_TRACK; then
							warn "the installed binary still lacks --single-track; cargo install may have picked up a non-spotty librespot from PATH."
							info "Try: rm -f \$HOME/.cargo/bin/librespot && re-run this wizard"
						fi
						info "  Persist for future shells by adding to ~/.bashrc:"
						info "      export PATH=\"\$HOME/.cargo/bin:\$PATH\""
					else
						warn "spotty still not visible in PATH after install."
					fi
				fi
			fi
		fi
	fi

	# 7b. Python venv for scan-spotify

	if command -v python3 >/dev/null 2>&1 \
		&& python3 -c 'import sys; sys.exit(0 if sys.version_info >= (3,8) else 1)' >/dev/null 2>&1 \
		&& python3 -c 'import venv' >/dev/null 2>&1; then

		_xdg_data=${XDG_DATA_HOME:-$HOME/.local/share}
		STREAMING_VENV="$_xdg_data/xwax/streaming-venv"

		if [ -x "$STREAMING_VENV/bin/python3" ]; then
			info "existing venv at $STREAMING_VENV"
			ask_yn "Upgrade spotipy in existing venv?" "Y"
			_do_venv=$REPLY
		else
			ask_yn "Create Python venv at $STREAMING_VENV (for scan-spotify)?" "Y"
			_do_venv=$REPLY
		fi

		if [ "$_do_venv" = y ]; then
			mkdir -p "$(dirname "$STREAMING_VENV")" \
				|| die "could not create $(dirname "$STREAMING_VENV")"
			if [ ! -x "$STREAMING_VENV/bin/python3" ]; then
				info "creating venv..."
				python3 -m venv "$STREAMING_VENV" \
					|| die "python3 -m venv failed"
			fi
			info "installing spotipy into venv..."
			"$STREAMING_VENV/bin/pip" install --upgrade pip >/dev/null \
				|| warn "pip upgrade failed (continuing)"
			if [ -f requirements-streaming.txt ]; then
				"$STREAMING_VENV/bin/pip" install --upgrade \
					-r requirements-streaming.txt \
					|| die "pip install -r requirements-streaming.txt failed"
			else
				"$STREAMING_VENV/bin/pip" install --upgrade 'spotipy>=2.23' \
					|| die "pip install spotipy failed"
			fi
			STREAMING_VENV_BUILT=true
			ok "venv ready at $STREAMING_VENV"
		else
			info "skipping venv creation; scan-spotify will fall back to system python3."
		fi
	else
		warn "python3 (>=3.8) with venv not available  ->  $(pkg_install_hint venv)"
		info "skipping venv setup; scan-spotify needs spotipy installed somewhere."
	fi

	# 7d. Make streaming scripts executable

	for _s in scan-soundcloud scan-spotify import-streaming; do
		if [ -f "$_s" ]; then
			if [ ! -x "$_s" ]; then
				chmod +x "$_s" 2>/dev/null \
					&& ok "chmod +x $_s" \
					|| warn "could not chmod +x $_s"
			else
				ok "$_s already executable"
			fi
		else
			warn "$_s not present in source tree"
		fi
	done

	# 7e. Spotify client id capture

	echo
	info "Spotify Web API needs a free 'client id' to scan playlists."
	info "Register an app at https://developer.spotify.com/dashboard"
	info "and set its redirect URI to http://127.0.0.1:8888/callback."
	info "(Spotify's policy now requires a loopback IP, not 'localhost'.)"
	ask_str "Spotify SPOTIFY_CLIENT_ID (leave blank to skip):" ""
	_client_id=$REPLY

	if [ -n "$_client_id" ]; then
		# The redirect URI must match exactly what's registered in the
		# Spotify dashboard. Default to 127.0.0.1 per Spotify's loopback
		# policy; allow override for users who registered something else.
		ask_str "Spotify redirect URI (must match dashboard exactly):" \
			"http://127.0.0.1:8888/callback"
		_redirect_uri=$REPLY

		_xdg_config=${XDG_CONFIG_HOME:-$HOME/.config}
		STREAMING_ENV_FILE="$_xdg_config/xwax/streaming.env"
		mkdir -p "$(dirname "$STREAMING_ENV_FILE")" \
			|| die "could not create $(dirname "$STREAMING_ENV_FILE")"

		_tmp="$STREAMING_ENV_FILE.tmp.$$"
		{
			printf '# xwax streaming environment\n'
			printf '# Source this before launching xwax with -s ./scan-spotify:\n'
			printf '#   . %s\n' "$STREAMING_ENV_FILE"
			printf '#\n'
			printf '# Generated by install-wizard on %s\n' "$(date -Iseconds 2>/dev/null || date)"
			printf '\n'
			printf 'export SPOTIFY_CLIENT_ID=%s\n' "\"$_client_id\""
			printf '\n'
			printf '# Must match the redirect URI registered in your Spotify\n'
			printf '# dashboard exactly. Spotify requires a loopback IP\n'
			printf '# (127.0.0.1, not localhost) for new apps since Apr 2025.\n'
			printf 'export SPOTIFY_REDIRECT_URI=%s\n' "\"$_redirect_uri\""
		} > "$_tmp" || die "could not write $_tmp"
		mv "$_tmp" "$STREAMING_ENV_FILE" \
			|| die "could not move $_tmp to $STREAMING_ENV_FILE"
		chmod 0600 "$STREAMING_ENV_FILE" 2>/dev/null || true
		SPOTIFY_CONFIGURED=true
		ok "wrote $STREAMING_ENV_FILE (mode 0600)"
	else
		info "no client id entered; skipping streaming.env."
	fi

	# 7f. One-time Zeroconf pairing for the spotty/librespot binary.
	#
	# Without cached credentials, import-streaming cannot fetch tracks
	# (it runs spotty --disable-discovery --single-track, which needs
	# pre-saved auth). The pairing flow here writes credentials into
	# $LIBRESPOT_CACHE; import-streaming reads from the same path.

	if $LIBRESPOT_OK && $LIBRESPOT_HAS_SINGLE_TRACK; then
		# Re-use existing credentials silently if already paired.
		if [ -f "$LIBRESPOT_CACHE/credentials.json" ] \
			|| [ -d "$LIBRESPOT_CACHE/credentials" ]; then
			ok "$LIBRESPOT_BIN_NAME credentials already present at $LIBRESPOT_CACHE"
			LIBRESPOT_PAIRED=true
		else
			echo
			info "Spotify needs a one-time login before import-streaming can"
			info "fetch tracks. The wizard will run $LIBRESPOT_BIN_NAME in the"
			info "foreground as a Connect target named 'xwax-test'."
			info ""
			info "Steps:"
			info "  1. Press ENTER to launch $LIBRESPOT_BIN_NAME here."
			info "  2. On any phone or desktop running the official Spotify"
			info "     app (logged in to your Premium account), tap the"
			info "     Connect-to-a-device icon and pick 'xwax-test'."
			info "  3. Once the Spotify app shows it's connected, return"
			info "     here and press Ctrl-C. Credentials are then saved to"
			info "     $LIBRESPOT_CACHE  and reused by import-streaming."
			info ""
			ask_yn "Run $LIBRESPOT_BIN_NAME pairing now?" "Y"
			if [ "$REPLY" = y ]; then
				mkdir -p "$LIBRESPOT_CACHE" \
					|| die "could not create $LIBRESPOT_CACHE"
				printf '\n  Press ENTER to launch %s, Ctrl-C inside it once paired... ' "$LIBRESPOT_BIN_NAME"
				IFS= read -r _ || true
				echo
				info "----- $LIBRESPOT_BIN_NAME output (Ctrl-C when paired) -----"
				# Trap our own SIGINT so Ctrl-C kills the child but
				# returns control to this wizard.
				trap : INT
				"$LIBRESPOT_BIN" \
					--name xwax-test \
					--cache "$LIBRESPOT_CACHE" \
					--backend pipe \
					--bitrate 320 \
					--device-type computer \
					>/dev/null || true
				trap - INT
				echo
				info "----- $LIBRESPOT_BIN_NAME stopped -----"
				if [ -f "$LIBRESPOT_CACHE/credentials.json" ] \
					|| [ -d "$LIBRESPOT_CACHE/credentials" ]; then
					LIBRESPOT_PAIRED=true
					ok "credentials saved at $LIBRESPOT_CACHE"
				else
					warn "no credentials saved at $LIBRESPOT_CACHE."
					info "Did you select 'xwax-test' in the Spotify app before Ctrl-C?"
					info "You can re-pair any time by running:"
					info "    $LIBRESPOT_BIN_NAME --name xwax-test --backend pipe --cache $LIBRESPOT_CACHE >/dev/null"
				fi
			else
				info "skipping pairing; you can pair later with:"
				info "    $LIBRESPOT_BIN_NAME --name xwax-test --backend pipe --cache $LIBRESPOT_CACHE >/dev/null"
				info "(--backend pipe avoids the rodio NoDeviceAvailable panic on systems"
				info " where cpal can't find a default ALSA device, e.g. Pi OS + PipeWire.)"
			fi
		fi
	elif $LIBRESPOT_OK; then
		warn "$LIBRESPOT_BIN_NAME lacks --single-track; pairing flow skipped."
		info "import-streaming needs --single-track support to fetch Spotify"
		info "tracks. Install the spotty fork via:"
		info "    cargo install --git https://github.com/michaelherger/librespot --branch spotty spotty"
		info "and re-run this wizard."
	fi
fi

# ---- Section 8: Summary -----------------------------------------------------

heading "Summary"

if $BUILT; then
	if [ -x ./xwax ]; then
		info "binary built : $WIZARD_DIR/xwax"
	fi
fi
if $INSTALLED; then
	info "installed to : $PREFIX/bin/xwax"
	info "man page     : $PREFIX/share/man/man1/xwax.1"
	XWAX_INVOKE="xwax"
elif $BUILT; then
	XWAX_INVOKE="./xwax"
else
	XWAX_INVOKE="./xwax"
fi

echo
info "Detected audio devices and example invocations:"
echo

if [ "$ENABLE_ALSA" = y ] && $ALSA_HAS_HW; then
	printf '  %sALSA cards%s\n' "$C_BOLD" "$C_RESET"
	# Use a temp file to extract first ALSA card; while-loops in pipes
	# run in subshells, which complicates capturing a value.
	_first_card=$(printf '%s\n' "$ALSA_DEVICE_LINES" \
		| sed -n 's/^card \([0-9][0-9]*\):.*/\1/p' | head -n1)
	printf '%s\n' "$ALSA_DEVICE_LINES" | while IFS= read -r _line; do
		printf '    %s\n' "$_line"
	done
	if [ -n "$_first_card" ]; then
		printf '    example: %s -a hw:%s,0\n' "$XWAX_INVOKE" "$_first_card"
	fi
fi

if [ "$ENABLE_JACK" = y ]; then
	printf '  %sJACK%s\n' "$C_BOLD" "$C_RESET"
	if $JACK_RUNNING; then
		printf '    server: running\n'
	else
		printf '    server: not running (start jackd or pipewire-jack first)\n'
	fi
	printf '    example: %s -j xwax-deck-1\n' "$XWAX_INVOKE"
fi

if [ "$ENABLE_OSS" = y ] && $OSS_HAS_HW; then
	printf '  %sOSS%s\n' "$C_BOLD" "$C_RESET"
	for _d in $OSS_DEVICES; do
		printf '    %s\n' "$_d"
	done
	_first_oss=$(printf '%s' "$OSS_DEVICES" | awk '{print $1}')
	if [ -n "$_first_oss" ]; then
		printf '    example: %s -d %s\n' "$XWAX_INVOKE" "$_first_oss"
	fi
fi

if [ "$DO_STREAMING" = y ]; then
	echo
	printf '  %sStreaming%s\n' "$C_BOLD" "$C_RESET"
	if $STREAMING_VENV_BUILT; then
		printf '    venv         : %s\n' "$STREAMING_VENV"
	fi
	if $SPOTIFY_CONFIGURED; then
		printf '    env file     : %s\n' "$STREAMING_ENV_FILE"
		printf '    source it    : . %s\n' "$STREAMING_ENV_FILE"
	fi
	if $LIBRESPOT_OK; then
		printf '    %-13s: %s\n' "$LIBRESPOT_BIN_NAME" "$LIBRESPOT_BIN"
		if $LIBRESPOT_PAIRED; then
			printf '    paired       : credentials at %s\n' "$LIBRESPOT_CACHE"
		else
			printf '    paired       : NO  (re-run: %s --name xwax-test --backend pipe --cache %s >/dev/null)\n' \
				"$LIBRESPOT_BIN_NAME" "$LIBRESPOT_CACHE"
		fi
		if ! $LIBRESPOT_HAS_SINGLE_TRACK; then
			printf '    warning      : %s lacks --single-track; Spotify import will fail.\n' \
				"$LIBRESPOT_BIN_NAME"
			printf '                   Install the spotty fork:\n'
			printf '                     cargo install --git https://github.com/michaelherger/librespot --branch spotty spotty\n'
		fi
	else
		printf '    librespot    : not installed (Spotify import will fail)\n'
		printf '                   Install the spotty fork:\n'
		printf '                     cargo install --git https://github.com/michaelherger/librespot --branch spotty spotty\n'
	fi
	printf '    example combined launch:\n'
	printf '      %s \\\n' "$XWAX_INVOKE"
	printf '        -i ./import-streaming \\\n'
	printf '        -s ./scan            -l ~/music \\\n'
	printf '        -s ./scan-soundcloud -l '\''https://soundcloud.com/yourname/likes'\'' \\\n'
	printf '        -s ./scan-spotify    -l liked \\\n'
	if [ "$ENABLE_ALSA" = y ] && [ -n "${_first_card:-}" ]; then
		printf '        -a hw:%s,0\n' "$_first_card"
	else
		printf '        -a hw:0,0\n'
	fi
fi

echo
ok "all done."
echo
